<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Ultraudio.MainWindow"
        Title="Ultraudio - Pure Hi-Fi"
        Width="450" Height="250"
        CanResize="False"
        Background="#121212"
        WindowStartupLocation="CenterScreen"
        Icon="avares://Ultraudio/Assets/icon.ico">
    
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="Ultraudio">
                <NativeMenu>
                    <NativeMenuItem Header="Acerca de Ultraudio"
                                    Click="AcercaDe_Click"/>

                    <NativeMenuItemSeparator/>

                    <NativeMenuItem Header="Salir"
                                    Gesture="Meta+Q"
                                    Click="Salir_Click"/>
                </NativeMenu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <StackPanel Spacing="20" Margin="30" VerticalAlignment="Center">
        <!-- Título -->
        <TextBlock Text="Ultraudio" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        <TextBlock Text="Bit-Perfect FLAC Player" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,-15,0,0"/>
        
        <!-- Nombre del archivo cargado -->
        <TextBlock Name="TxtRuta" Text="Ningún archivo seleccionado" Foreground="#A0A0A0" FontStyle="Italic" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
        
        <!-- Etiqueta técnica estilo audiófilo -->
        <Border Name="BorderTechInfo" Background="#222222" CornerRadius="4" Padding="10,4" HorizontalAlignment="Center" IsVisible="False">
            <TextBlock Name="TxtTechInfo" Text="FLAC • 16-bit • 44.1 kHz • 900 kbps" Foreground="#4CAF50" FontSize="12" FontFamily="Monospace" HorizontalAlignment="Center"/>
        </Border>
        
        <!-- Controles de reproducción -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,10,0,0">
            <Button Name="BtnCargar" Content="📁 Cargar FLAC" Width="120" HorizontalContentAlignment="Center" Background="#333333" Foreground="White"/>
            <Button Name="BtnReproducir" Content="▶ Play" Width="90" HorizontalContentAlignment="Center" Background="#2E7D32" Foreground="White"/>
            <Button Name="BtnDetener" Content="■ Stop" Width="90" HorizontalContentAlignment="Center" Background="#C62828" Foreground="White"/>
        </StackPanel>
        
        <!-- Versión en la esquina -->
        <TextBlock Name="TxtVersion" 
                   Text="" 
                   Foreground="#555555" 
                   FontSize="10" 
                   HorizontalAlignment="Right" 
                   VerticalAlignment="Bottom" 
                   Margin="0,0,10,10"/>
    </StackPanel>
</Window>