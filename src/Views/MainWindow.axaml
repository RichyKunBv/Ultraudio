<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Ultraudio.Views.Controls"
        xmlns:local="clr-namespace:Ultraudio"
        x:Class="Ultraudio.MainWindow"
        Title="Ultraudio – Pure Hi-Fi"
        MinWidth="720" MinHeight="560"
        Width="820" Height="600"
        Background="#0A0A0A"
        WindowStartupLocation="CenterScreen"
        Icon="avares://Ultraudio/Assets/icon.ico"
        PointerWheelChanged="Window_PointerWheelChanged">

    <!-- Native menu -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="Ultraudio">
                <NativeMenu>
                    <NativeMenuItem Header="Acerca de Ultraudio" Click="AcercaDe_Click"/>
                    <NativeMenuItem Header="Comprobar actualizaciones" Click="UpdateCheck_Click"/>
                    <NativeMenuItem Header="Historial de actualizaciones" Click="UpdateHistory_Click"/>
                    <NativeMenuItemSeparator/>
                    <NativeMenuItem Header="Salir" Gesture="Meta+Q" Click="Salir_Click"/>
                </NativeMenu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <Window.Styles>
        <!-- Transport button base -->
        <Style Selector="Button.transport">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.transport:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>
        <Style Selector="Button.transport-primary">
            <Setter Property="Background" Value="#1B6B3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.transport-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22883F"/>
        </Style>
        <Style Selector="Button.load-btn">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.load-btn:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2A2A2A"/>
        </Style>
        <Style Selector="Button.toggle-active">
            <Setter Property="Background" Value="#0D3D1F"/>
            <Setter Property="Foreground" Value="#00E576"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1B6B3A"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.toggle-inactive">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="TextBox.search">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#252525"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Slider">
            <Setter Property="Foreground" Value="#1B6B3A"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#141414"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="#0D2E18"/>
        </Style>
    </Window.Styles>

    <!-- Root layout: top player + bottom playlist -->
    <Grid RowDefinitions="Auto,*" Margin="0">

        <!-- ═══════════════════════════════════════════════ TOP PLAYER PANEL -->
        <Border Grid.Row="0" Background="#111111" Padding="18,16">
            <Grid ColumnDefinitions="Auto,*">

                <!-- Cover Art -->
                <Border Grid.Column="0" Width="160" Height="160"
                        CornerRadius="8" ClipToBounds="True"
                        Background="#1A1A1A" Margin="0,0,18,0">
                    <Panel>
                        <!-- Placeholder when no cover -->
                        <TextBlock Name="TxtNoCover" Text="♪" FontSize="64"
                                   Foreground="#2A2A2A"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                        <!-- Actual cover art -->
                        <Image Name="ImgCoverArt" Stretch="UniformToFill"
                               IsVisible="False"/>
                    </Panel>
                </Border>

                <!-- Right side: metadata + controls -->
                <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                    <!-- Track title + favorite + tech badge -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,4">
                        <TextBlock Grid.Column="0" Name="TxtTitle"
                                   Text="Sin pista seleccionada"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="White"
                                   TextTrimming="CharacterEllipsis"/>
                        <!-- Update Button -->
                        <Button Grid.Column="1" Name="BtnUpdate"
                                Classes="transport" FontSize="18"
                                Content="✨" ToolTip.Tip="Nueva versión disponible"
                                Click="BtnUpdate_Click" Margin="8,0,0,0" IsVisible="False"/>
                        <!-- Favorite star -->
                        <Button Grid.Column="2" Name="BtnFavorite"
                                Classes="transport" FontSize="18"
                                Content="☆" ToolTip.Tip="Marcar como favorito"
                                Click="BtnFavorite_Click" Margin="8,0,0,0"/>
                        <!-- Settings gear -->
                        <Button Grid.Column="3" Name="BtnSettings"
                                Classes="transport" Content="⚙"
                                ToolTip.Tip="Configuración"
                                Click="BtnSettings_Click"/>
                    </Grid>

                    <!-- Artist / Album -->
                    <TextBlock Grid.Row="1" Name="TxtArtist"
                               Text="" Foreground="#AAAAAA" FontSize="13"
                               TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                    <TextBlock Grid.Row="1" Name="TxtAlbum"
                               Text="" Foreground="#666666" FontSize="12"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,16,0,0"/>

                    <!-- Tech badge row -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                        <Border Name="BorderTechInfo" Background="#1A2E1A" CornerRadius="4"
                                Padding="8,3" IsVisible="False">
                            <TextBlock Name="TxtTechInfo" Foreground="#00E576"
                                       FontSize="11" FontFamily="Cascadia Code,Consolas,Monospace"/>
                        </Border>
                        <Border Name="BorderReplayGain" Background="#1E1A2E" CornerRadius="4"
                                Padding="8,3" IsVisible="False">
                            <TextBlock Name="TxtReplayGain" Foreground="#8B80FF"
                                       FontSize="11" FontFamily="Cascadia Code,Consolas,Monospace"/>
                        </Border>
                    </StackPanel>

                    <!-- Spectrum Visualizer -->
                    <Border Grid.Row="3" Height="48" Margin="0,10,0,0"
                            CornerRadius="4" ClipToBounds="True">
                        <controls:SpectrumVisualizerControl Name="SpectrumViz"/>
                    </Border>

                    <!-- Seekbar -->
                    <Grid Grid.Row="4" ColumnDefinitions="40,*,40" Margin="0,8,0,0">
                        <TextBlock Grid.Column="0" Name="TxtTiempoActual"
                                   Text="00:00" Foreground="#666666"
                                   FontSize="11" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Name="SliderProgreso"
                                Minimum="0" Maximum="100"
                                ValueChanged="SliderProgreso_ValueChanged"/>
                        <TextBlock Grid.Column="2" Name="TxtTiempoTotal"
                                   Text="00:00" Foreground="#666666"
                                   FontSize="11" VerticalAlignment="Center"
                                   TextAlignment="Right"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════ TRANSPORT + PLAYLIST -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*,Auto" Background="#0A0A0A">

            <!-- Transport bar -->
            <Border Grid.Row="0" Background="#0F0F0F"
                    BorderBrush="#1A1A1A" BorderThickness="0,0,0,1"
                    Padding="18,10">
                <Grid ColumnDefinitions="*,Auto">
                    <!-- Left: transport buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                Spacing="4" VerticalAlignment="Center">
                        <Button Name="BtnAnterior" Classes="transport" Content="⏮"
                                ToolTip.Tip="Anterior (←)" Click="BtnAnterior_Click"/>
                        <Button Name="BtnReproducir" Classes="transport-primary" Content="▶"
                                ToolTip.Tip="Reproducir/Pausar (Espacio)" Click="BtnReproducir_Click"/>
                        <Button Name="BtnSiguiente" Classes="transport" Content="⏭"
                                ToolTip.Tip="Siguiente (→)" Click="BtnSiguiente_Click"/>

                        <!-- Separator -->
                        <Border Width="1" Height="20" Background="#2A2A2A" Margin="6,0"/>

                        <Button Name="BtnShuffle" Classes="toggle-inactive" Content="⇄"
                                ToolTip.Tip="Aleatorio (S)" Click="BtnShuffle_Click"/>
                        <Button Name="BtnRepeat" Classes="toggle-inactive" Content="↺"
                                ToolTip.Tip="Repetir (R)" Click="BtnRepeat_Click"/>
                        <Button Name="BtnMute" Classes="transport" Content="🔊"
                                ToolTip.Tip="Silenciar (M)" Click="BtnMute_Click"/>
                    </StackPanel>

                    <!-- Right: volume -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="VOL" Foreground="#444444" FontSize="10"
                                   VerticalAlignment="Center" LetterSpacing="1"/>
                        <Slider Name="SliderVolumen" Minimum="0" Maximum="1" Value="1"
                                Width="100" ValueChanged="SliderVolumen_ValueChanged"/>
                        <TextBlock Name="TxtVolumePercent" Text="100%"
                                   Foreground="#666666" FontSize="11"
                                   VerticalAlignment="Center" Width="34"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Search bar -->
            <Grid Grid.Row="1" Margin="18,10,18,6" ColumnDefinitions="*,Auto">
                <TextBox Grid.Column="0" Name="TxtSearch" Classes="search"
                         PlaceholderText="🔍  Buscar pistas, artistas, álbumes..."
                         TextChanged="TxtSearch_TextChanged"/>
                <TextBlock Grid.Column="1" Name="TxtPlaylistCount"
                           Foreground="#444444" FontSize="11"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>

            <!-- Playlist -->
            <Border Grid.Row="2" Margin="10,0,10,0" CornerRadius="8"
                    Background="#0D0D0D" ClipToBounds="True">
                <ListBox Name="ListaReproduccion"
                         Background="Transparent"
                         SelectionChanged="ListaReproduccion_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:PlaylistItemViewModel}">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                                <!-- Playing indicator -->
                                <TextBlock Grid.Column="0" Name="TxtPlayingDot"
                                           Text="▶" Foreground="#00E576" FontSize="9"
                                           Width="16" VerticalAlignment="Center"
                                           IsVisible="{Binding IsPlaying}"/>
                                <!-- Track title -->
                                <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                                           Foreground="{Binding TitleColor}"
                                           FontSize="13" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                                <!-- Artist -->
                                <TextBlock Grid.Column="2" Text="{Binding Track.Artist}"
                                           Foreground="#555555" FontSize="11"
                                           VerticalAlignment="Center" Margin="8,0"
                                           TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                                <!-- Duration -->
                                <TextBlock Grid.Column="3" Text="{Binding Track.DurationDisplay}"
                                           Foreground="#444444" FontSize="11"
                                           VerticalAlignment="Center" Width="40"
                                           TextAlignment="Right"/>
                                <!-- Favorite star -->
                                <Button Grid.Column="4" Content="{Binding FavStar}"
                                        Foreground="{Binding FavColor}"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="4,0" FontSize="14"
                                        VerticalAlignment="Center"
                                        Click="FavButton_Click" Tag="{Binding}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- Load buttons -->
            <Border Grid.Row="3" Padding="10,8" Background="#0A0A0A">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Name="BtnCargarArchivo" Classes="load-btn"
                                Content="📄 Añadir Archivos" Click="BtnCargarArchivo_Click"/>
                        <Button Name="BtnCargarCarpeta" Classes="load-btn"
                                Content="📁 Añadir Carpeta" Click="BtnCargarCarpeta_Click"/>
                        <Button Name="BtnCargarCue" Classes="load-btn"
                                Content="📋 Hoja CUE" Click="BtnCargarCue_Click"/>
                        <Button Name="BtnCargarCd" Classes="load-btn"
                                Content="💿 CD Audio" Click="BtnCargarCd_Click"/>
                        <Border Width="1" Height="20" Background="#2A2A2A" Margin="2,0"/>
                        <Button Name="BtnMoveUp" Classes="load-btn"
                                Content="↑" Click="BtnMoveUp_Click" ToolTip.Tip="Subir selección"/>
                        <Button Name="BtnMoveDown" Classes="load-btn"
                                Content="↓" Click="BtnMoveDown_Click" ToolTip.Tip="Bajar selección"/>
                        <Border Width="1" Height="20" Background="#2A2A2A" Margin="2,0"/>
                        <Button Name="BtnSavePlaylist" Classes="load-btn"
                                Content="💾 Guardar" Click="BtnSavePlaylist_Click"/>
                        <Button Name="BtnClearPlaylist" Classes="load-btn"
                                Content="✕ Limpiar" Click="BtnClearPlaylist_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>