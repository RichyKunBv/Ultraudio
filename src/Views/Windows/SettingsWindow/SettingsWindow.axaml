<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Ultraudio.Views.Windows.SettingsWindow"
        Title="Configuración – Ultraudio"
        Width="520" Height="500"
        CanResize="False"
        Background="#0F0F0F"
        WindowStartupLocation="CenterOwner"
        Icon="avares://Ultraudio/Assets/icon.ico">

    <Window.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="LetterSpacing" Value="1.5"/>
        </Style>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="TextBlock.value">
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="Border.section">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style Selector="ToggleSwitch">
            <Setter Property="OnContent" Value=""/>
            <Setter Property="OffContent" Value=""/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Configuración" FontSize="22" FontWeight="Bold" Foreground="White"/>
            <TextBlock Text="Configuración de Ultraudio" FontSize="12" Foreground="#666666"/>
        </StackPanel>

        <!-- Settings Panels -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="0">

                <!-- Audio Device -->
                <TextBlock Text="SALIDA DE AUDIO" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Dispositivo de salida" Classes="label"/>
                                <TextBlock Text="Selecciona tu DAC o interfaz de audio" Classes="value" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1" Name="ComboDevices" Width="180" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="#2A2A2A" Height="1"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Modo exclusivo" Classes="label"/>
                                <TextBlock Text="WASAPI (Win) / Hog Mode (Mac) — evita el mixer del sistema" Classes="value" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" Name="ToggleExclusive" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="#2A2A2A" Height="1"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Modo RAM" Classes="label"/>
                                <TextBlock Text="Cargar archivo completo a memoria antes de reproducir" Classes="value" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" Name="ToggleRamMode" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Playback -->
                <TextBlock Text="REPRODUCCIÓN" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Reproducción sin pausas" Classes="label"/>
                                <TextBlock Text="Pre-cargar la siguiente pista para transiciones sin cortes" Classes="value" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" Name="ToggleGapless" VerticalAlignment="Center"/>
                        </Grid>

                        <Separator Background="#2A2A2A" Height="1"/>

                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Visualizador de espectro" Classes="label"/>
                                <TextBlock Text="Espectro FFT en tiempo real (ligero uso de CPU)" Classes="value" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" Name="ToggleSpectrum" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- CD Audio -->
                <TextBlock Text="AUDIO CD" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Habilitar Audio CD" Classes="label"/>
                            <TextBlock Text="Mostrar el botón de Audio CD (requiere librerías basscd)" Classes="value" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" Name="ToggleCd" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- HTTP Remote API -->
                <TextBlock Text="CONTROL REMOTO" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <StackPanel Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="HTTP API" Classes="label"/>
                                <TextBlock Text="Habilitar API de control remoto HTTP local" Classes="value" Margin="0,2,0,0"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" Name="ToggleHttpApi" VerticalAlignment="Center"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,Auto" Name="GridHttpPort">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Puerto API" Classes="label"/>
                                <TextBlock Text="http://127.0.0.1:{port}/status" Classes="value" Margin="0,2,0,0" Name="TxtApiUrl"/>
                            </StackPanel>
                            <NumericUpDown Grid.Column="1" Name="NumPort" Minimum="1024" Maximum="65535" Width="120"
                                           VerticalAlignment="Center" FormatString="0"
                                           Foreground="White" Background="#2A2A2A"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Keyboard Shortcuts -->
                <TextBlock Text="ATAJOS DE TECLADO" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Espacio" Classes="label"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Reproducir / Pausar" Classes="value"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="→ / ←" Classes="label"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="Adelantar / Atrasar 5s" Classes="value"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + → / ←" Classes="label"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Siguiente / Anterior" Classes="value"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl + ↑ / ↓" Classes="label"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Volumen +10% / -10%" Classes="value"/>
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl + M" Classes="label"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Silenciar / Activar" Classes="value"/>
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ctrl + S" Classes="label"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="Alternar aleatorio" Classes="value"/>
                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Ctrl + R" Classes="label"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="Cambiar modo repetir" Classes="value"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Ctrl + B" Classes="label"/>
                        <TextBlock Grid.Row="7" Grid.Column="1" Text="Favorito de pista actual" Classes="value"/>
                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Ctrl + F" Classes="label"/>
                        <TextBlock Grid.Row="8" Grid.Column="1" Text="Buscar en lista" Classes="value"/>
                        <TextBlock Grid.Row="9" Grid.Column="1" Text="Para macOS Ctrl es Command" Classes="label"/>

                    </Grid>
                </Border>

                <!-- Updates -->
                <TextBlock Text="ACTUALIZACIONES" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Buscar actualizaciones" Classes="label"/>
                            <TextBlock Text="Buscar si hay una nueva versión disponible" Classes="value" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Name="BtnOpenUpdateWindow" Content="Buscar Actualizaciones"
                                Background="#2A2A2A" Foreground="#CCCCCC" Padding="12,6"
                                VerticalAlignment="Center" Click="BtnOpenUpdateWindow_Click"/>
                    </Grid>
                </Border>

                <!-- About -->
                <TextBlock Text="ACERCA DE" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Acerca de Ultraudio" Classes="label"/>
                            <TextBlock Text="Información sobre Ultraudio" Classes="value" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Name="BtnOpenAboutWindow" Content="Acerca de" Background="#2A2A2A" Foreground="#CCCCCC" Padding="12,6" VerticalAlignment="Center" Click="BtnOpenAboutWindow_Click"/>
                    </Grid>
                </Border>

                <!-- History -->
                <TextBlock Text="HISTORIAL" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Historial de versiones" Classes="label"/>
                            <TextBlock Text="Historial de Ultraudio" Classes="value" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Name="BtnOpenHistoryWindow" Content="Historial" Background="#2A2A2A" Foreground="#CCCCCC" Padding="12,6" VerticalAlignment="Center" Click="BtnOpenHistoryWindow_Click"/>
                    </Grid>
                </Border>

                                <!-- Manual -->
                <TextBlock Text="MANUAL" Classes="header" Margin="2,0,0,8"/>
                <Border Classes="section">
                    <Grid ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Manuel" Classes="label"/>
                            <TextBlock Text="Manual de Usuario" Classes="value" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Name="BtnOpenManualWindow" Content="Manual" Background="#2A2A2A" Foreground="#CCCCCC" Padding="12,6" VerticalAlignment="Center" Click="BtnOpenManualWindow_Click"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,16,0,0">
            <TextBlock Grid.Column="0" Name="TxtVersion" Foreground="#444444" FontSize="11" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Name="BtnCancel" Content="Cancelar"
                    Background="#2A2A2A" Foreground="#CCCCCC"
                    Padding="20,8" Margin="0,0,10,0" Click="BtnCancel_Click"/>
            <Button Grid.Column="2" Name="BtnSave" Content="Guardar"
                    Background="#1B6B3A" Foreground="White"
                    Padding="20,8" Click="BtnSave_Click"/>
        </Grid>
    </Grid>
</Window>
