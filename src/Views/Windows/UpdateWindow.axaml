<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Ultraudio.Views.Windows.UpdateWindow"
        Title="Actualizaciones"
        Width="400" Height="250"
        CanResize="False"
        Background="#0F0F0F"
        WindowStartupLocation="CenterOwner"
        Icon="avares://Ultraudio/Assets/icon.ico">

    <Grid RowDefinitions="*,Auto" Margin="20">
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="15">
            <TextBlock Name="TxtStatus" Text="Checking for updates..." FontSize="16" TextWrapping="Wrap" TextAlignment="Center" Foreground="Gray"/>
            <Button Name="BtnLatestRelease" Content="✨ Download Latest" Background="#1B6B3A" Foreground="White" Padding="15,8" HorizontalAlignment="Center" IsVisible="False" Click="BtnLatestRelease_Click" Cursor="Hand" CornerRadius="4"/>
        </StackPanel>

        <Button Grid.Row="1" Content="Cerrar" HorizontalAlignment="Center" Background="#2A2A2A" Foreground="#CCCCCC" Padding="20,8" Click="BtnClose_Click" Cursor="Hand" CornerRadius="4"/>
    </Grid>
</Window>
